# ─── CORE CONFIGURATION ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
WEB_APP_URL=http://localhost:5173
MOBILE_APP_URL=exp://localhost:8081

# ─── DATABASE & CACHE ────────────────────────────────────────────────────────
# Local MongoDB instance or Atlas mock string

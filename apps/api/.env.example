# ==================================================
# DonorLink API Environment Configuration
# ==================================================

# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Database
MONGO_URI=mongodb+srv://<user_name>:<db_password>@cluster0.hgzxxxv.mongodb.net/donorlink?authSource=admin
    
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=donorlink_redis_pass

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP (Email)
SMTP_FROM=''
SMTP_HOST='smtp-relay.brevo.com'
SMTP_PORT=587
SMTP_USER=''
SMTP_PASS=''

# SMS
SMS_API_URL=https://api.sms-provider.com
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=DonorLink

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ML Intelligence Service
ML_SERVICE_URL=http://localhost:8000
ML_API_KEY=dl-ml-dev-key-change-in-prod
ML_TIMEOUT_MS=10000
ML_MAX_RETRIES=2
# ─── CORE CONFIGURATION ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
WEB_APP_URL=http://localhost:5173
MOBILE_APP_URL=exp://localhost:8081

# ─── DATABASE & CACHE ────────────────────────────────────────────────────────
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/donorlink
MONGODB_URI=
REDIS_URL=redis://localhost:6379

# ─── AUTHENTICATION (JWT) ─────────────────────────────────────────────────────
# Generate 32+ character random strings for secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── COMMUNICATIONS ───────────────────────────────────────────────────────────
# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Africa's Talking (Alternative SMS/USSD)
AT_API_KEY=
AT_USERNAME=

# Resend (Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@donorlink.et

# ─── INFRASTRUCTURE & STORAGE ─────────────────────────────────────────────────
# Firebase Admin (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Vercel Blob or similar for file storage
BLOB_READ_WRITE_TOKEN=

# Mapbox (Location Services)
MAPBOX_ACCESS_TOKEN=

# ─── SECURITY & RATE LIMITING ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── INITIAL SEEDING / SUPER ADMIN ───────────────────────────────────────────
SUPER_ADMIN_PHONE=
SUPER_ADMIN_PASSWORD=